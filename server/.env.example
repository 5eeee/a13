PORT=3001

# Основной режим: PostgreSQL. Поднимите БД (docker compose up -d) или создайте вручную (scripts/init-postgres-local.sql).
DATABASE_URL=postgresql://a13:a13@127.0.0.1:5432/a13

# Если DATABASE_URL пустой или строка закомментирована — API использует только файл server/data/cms.json (режим без БД).

# Опционально: путь к JSON при файловом режиме или для миграции
# DATA_FILE=./data/cms.json

# Если задан — для PUT /api/documents/* нужен заголовок X-Admin-Key
ADMIN_API_KEY=

# Публичный CORS: через запятую, иначе разрешён любой (только для разработки)
# CORS_ORIGIN=https://a13buro.ru,https://www.a13buro.ru

# Уведомления о заявках (POST /api/leads) — только здесь, не в браузере
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Почта в офис (если пусто SMTP_HOST — письмо о заявке не шлётся)
# LEAD_TO_EMAIL=info@a13bureau.ru
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# SMTP_SECURE=0
# SMTP_FROM=

# Лимит заявок с одного IP (за окно)
# LEAD_RATE_MAX=20
# LEAD_RATE_WINDOW_MS=60000

# CRM, если нужен
# CRM_WEBHOOK_URL=
